<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and folders load normally
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send everything else to the SPA entry point
  RewriteRule . /index.html [L]
</IfModule>
